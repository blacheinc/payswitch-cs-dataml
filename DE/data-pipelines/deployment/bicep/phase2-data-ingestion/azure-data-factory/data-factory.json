        "annotations": [],
        "typeProperties": {
          "server": "[parameters('metadataPostgresServerFqdn')]",
          "database": "postgres",
          "username": "postgres_admin",
          "encryptedCredential": "",
          "password": {
            "type": "AzureKeyVaultSecret",
            "store": {
              "type": "LinkedServiceReference",
              "referenceName": "[variables('keyVaultLinkedServiceName')]"
            },
            "secretName": "postgres-admin-password"
          }
