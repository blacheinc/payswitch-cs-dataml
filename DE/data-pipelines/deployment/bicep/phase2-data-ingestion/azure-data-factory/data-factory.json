    },
    {
      "condition": "[parameters('deployLegacyStarterCatalog')]",
      "type": "Microsoft.DataFactory/factories/linkedservices",
      "apiVersion": "2018-06-01",
      "name": "[format('{0}/{1}', variables('dataFactoryName'), 'RestApiGeneric')]",
      "properties": {
        "type": "RestService",
        "typeProperties": {
          "url": "https://api.example.com",
          "enableServerCertificateValidation": true,
          "authenticationType": "Anonymous"
        },
        "annotations": []
      },
      "dependsOn": [
        "[resourceId('Microsoft.DataFactory/factories', variables('dataFactoryName'))]"
      ]
    },
    {
      "condition": "[parameters('deployLegacyStarterCatalog')]",
      "type": "Microsoft.DataFactory/factories/datasets",
      "apiVersion": "2018-06-01",
      "name": "[format('{0}/{1}', variables('dataFactoryName'), 'RawDataLakeJson')]",
      "properties": {
        "linkedServiceName": {
          "referenceName": "AzureDataLakeStorage",
          "type": "LinkedServiceReference"
        },
        "parameters": {
          "folderPath": {
            "type": "String"
          },
          "fileName": {
            "type": "String"
          }
        },
        "type": "Json",
        "typeProperties": {
          "location": {
            "type": "AzureBlobFSLocation",
            "folderPath": {
              "value": "@dataset().folderPath",
              "type": "Expression"
            },
            "fileName": {
              "value": "@dataset().fileName",
              "type": "Expression"
            },
            "fileSystem": "raw"
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.DataFactory/factories', variables('dataFactoryName'))]",
        "[resourceId('Microsoft.DataFactory/factories/linkedservices', variables('dataFactoryName'), 'AzureDataLakeStorage')]"
      ]
