{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "location": {
            "value": "eastus2"
        },
        "namingPrefix": {
            "value": "OVERRIDE-org-project-dev"
        },
        "deploymentEnvironment": {
            "value": "dev"
        },
        "dataLakeStorageAccountName": {
            "value": "REPLACE_DATALAKE_STORAGE_ACCOUNT_NAME"
        },
        "keyVaultName": {
            "value": "REPLACE_KEY_VAULT_NAME"
        },
        "serviceBusNamespaceName": {
            "value": "REPLACE_SERVICE_BUS_NAMESPACE_NAME"
        },
        "sourceBlobStorageAccountName": {
            "value": "REPLACE_BLOB_STORAGE_ACCOUNT_NAME"
        },
        "metadataPostgresServerFqdn": {
            "value": "REPLACE_POSTGRES_SERVER_NAME.postgres.database.azure.com"
        },
        "metadataPostgresDatabaseName": {
            "value": "credit_scoring"
        },
        "metadataPostgresUsername": {
            "value": "postgres_admin"
        },
        "metadataPostgresPasswordSecretName": {
            "value": "postgres-admin-password"
        },
        "privateNetworkMode": {
            "value": true
        },
        "tags": {
            "value": {
                "Environment": "dev",
                "ManagedBy": "Bicep",
                "Project": "Credit-Scoring"
            }
        }
    }
}
