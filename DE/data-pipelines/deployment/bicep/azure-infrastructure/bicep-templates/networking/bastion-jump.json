{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.42.1.51946",
      "templateHash": "1627296360377636071"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "metadata": {
        "description": "Azure region for deployment"
      }
    },
    "namingPrefix": {
      "type": "string",
      "metadata": {
        "description": "Naming prefix for resources"
      }
    },
    "bastionSubnetId": {
      "type": "string",
      "metadata": {
        "description": "Subnet ID for AzureBastionSubnet"
      }
    },
    "jumpSubnetId": {
      "type": "string",
      "metadata": {
        "description": "Subnet ID for the jump VM NIC"
      }
    },
    "jumpVmAdminUsername": {
      "type": "string",
      "metadata": {
        "description": "Windows admin username"
      }
    },
    "jumpVmAdminPassword": {
      "type": "securestring",
      "metadata": {
        "description": "Windows admin password for jump VM"
      }
    },
    "jumpVmSize": {
      "type": "string",
      "metadata": {
        "description": "Jump VM size"
      }
    },
    "tags": {
      "type": "object",
      "metadata": {
        "description": "Resource tags"
      }
    },
    "deploy": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "When false, no Bastion/jump resources are created (outputs remain empty strings)."
      }
    }
  },
  "resources": [
    {
      "condition": "[parameters('deploy')]",
      "type": "Microsoft.Network/publicIPAddresses",
      "apiVersion": "2023-09-01",
      "name": "[format('{0}-bastion-pip', parameters('namingPrefix'))]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "sku": {
        "name": "Standard",
        "tier": "Regional"
      },
      "properties": {
        "publicIPAllocationMethod": "Static"
      }
    },
    {
      "condition": "[parameters('deploy')]",
      "type": "Microsoft.Network/bastionHosts",
      "apiVersion": "2023-09-01",
      "name": "[format('{0}-bastion', parameters('namingPrefix'))]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "sku": {
        "name": "Standard"
      },
      "properties": {
        "ipConfigurations": [
          {
            "name": "bastion-ip-config",
            "properties": {
              "publicIPAddress": {
                "id": "[resourceId('Microsoft.Network/publicIPAddresses', format('{0}-bastion-pip', parameters('namingPrefix')))]"
              },
              "subnet": {
                "id": "[parameters('bastionSubnetId')]"
              }
            }
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/publicIPAddresses', format('{0}-bastion-pip', parameters('namingPrefix')))]"
      ]
    },
    {
      "condition": "[parameters('deploy')]",
      "type": "Microsoft.Network/networkInterfaces",
      "apiVersion": "2023-09-01",
      "name": "[format('{0}-jump-nic', parameters('namingPrefix'))]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "ipConfigurations": [
          {
            "name": "ipconfig1",
            "properties": {
              "subnet": {
                "id": "[parameters('jumpSubnetId')]"
              },
              "privateIPAllocationMethod": "Dynamic"
            }
          }
        ]
      }
    },
    {
      "condition": "[parameters('deploy')]",
      "type": "Microsoft.Compute/virtualMachines",
      "apiVersion": "2024-07-01",
      "name": "[format('{0}-jump-vm', parameters('namingPrefix'))]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "hardwareProfile": {
          "vmSize": "[parameters('jumpVmSize')]"
        },
        "storageProfile": {
          "imageReference": {
            "publisher": "MicrosoftWindowsServer",
            "offer": "WindowsServer",
            "sku": "2022-datacenter-azure-edition",
            "version": "latest"
          },
          "osDisk": {
            "name": "[format('{0}-jump-os', parameters('namingPrefix'))]",
            "caching": "ReadWrite",
            "createOption": "FromImage",
            "managedDisk": {
              "storageAccountType": "StandardSSD_LRS"
            }
          }
        },
        "osProfile": {
          "computerName": "jumpvmwin",
          "adminUsername": "[parameters('jumpVmAdminUsername')]",
          "adminPassword": "[parameters('jumpVmAdminPassword')]",
          "windowsConfiguration": {
            "provisionVMAgent": true,
            "enableAutomaticUpdates": true
          }
        },
        "networkProfile": {
          "networkInterfaces": [
            {
              "id": "[resourceId('Microsoft.Network/networkInterfaces', format('{0}-jump-nic', parameters('namingPrefix')))]",
              "properties": {
                "primary": true
              }
            }
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/networkInterfaces', format('{0}-jump-nic', parameters('namingPrefix')))]"
      ]
    }
  ],
  "outputs": {
    "bastionHostName": {
      "type": "string",
      "value": "[if(parameters('deploy'), format('{0}-bastion', parameters('namingPrefix')), '')]"
    },
    "jumpVmName": {
      "type": "string",
      "value": "[if(parameters('deploy'), format('{0}-jump-vm', parameters('namingPrefix')), '')]"
    }
  }
}