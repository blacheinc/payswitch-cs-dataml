# ─────────────────────────────────────────────────────────────────────
# PaySwitch Credit Scoring — environment template
# ─────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your Azure resource values.
# .env is gitignored; .env.example is the committed template.
#
# Every Function App also needs these set as App Settings in Azure
# (az functionapp config appsettings set ...). See deployment_guide.md.
# ─────────────────────────────────────────────────────────────────────


# ── Service Bus ──────────────────────────────────────────────────────
# Used by: orchestrator, all 4 training agents.
# Get with:
#   az servicebus namespace authorization-rule keys list \
#     --resource-group <their-data-rg> \
#     --namespace-name <their-sb> \
#     --name RootManageSharedAccessKey \
#     --query primaryConnectionString -o tsv
SERVICE_BUS_CONNECTION="Endpoint=sb://<their-sb>.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=..."


# ── Blob Storage (data + model artifacts) ────────────────────────────
# Used by: orchestrator, all 4 training agents, customer service.
# Holds containers: curated, model-artifacts.
# Get with:
#   az storage account show-connection-string \
#     --name <their-storage> \
#     --resource-group <their-data-rg> \
#     --query connectionString -o tsv
STORAGE_CONNECTION="DefaultEndpointsProtocol=https;AccountName=<their-storage>;AccountKey=...;EndpointSuffix=core.windows.net"


# ── Azure Machine Learning ───────────────────────────────────────────
# Used by: orchestrator, all 4 training agents.
# Required for model registry reads/writes via azure-ai-ml SDK.
AZURE_ML_SUBSCRIPTION_ID="<their-subscription-guid>"
AZURE_ML_RESOURCE_GROUP="<their-ml-rg>"
AZURE_ML_WORKSPACE_NAME="<their-workspace>"


# ── MLflow (training agents only) ────────────────────────────────────
# Local experiment tracking. Defaults to sqlite in the function's /tmp/.
# Override with a tracking server URI only if you've set one up.
MLFLOW_TRACKING_URI="sqlite:////tmp/mlflow.db"


# ── Hyperparameter tuning (training agents) ──────────────────────────
# "true"  → Optuna, 50 trials per model (slow, production-quality)
# "false" → fixed defaults (fast smoke tests)
ENABLE_HYPERPARAMETER_TUNING="true"


# ── Azure OpenAI (customer service agent only) ───────────────────────
# Deployment must be gpt-4.1-mini version 2025-04-14 or later.
# gpt-4o-mini 2024-07-18 was deprecated on 2026-03-31.
AZURE_OPENAI_ENDPOINT="https://<their-openai>.openai.azure.com/"
AZURE_OPENAI_DEPLOYMENT="gpt-4-1-mini"
AZURE_OPENAI_API_KEY="<their-openai-key>"
AZURE_OPENAI_API_VERSION="2024-10-21"


# ── Anthropic fallback (optional, customer service) ──────────────────
# Leave these commented unless you want Claude instead of Azure OpenAI.
# When ANTHROPIC_API_KEY is set, the customer service agent uses it
# and ignores the AZURE_OPENAI_* variables.
# ANTHROPIC_API_KEY=""
# ANTHROPIC_MODEL="claude-3-5-haiku-20241022"
